# ==========================================
# WebhookGateway - Variaveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores
# cp .env.example .env

# --- Obrigatorias ---

# URL de conexao do RabbitMQ (formato: amqp://usuario:senha@host:porta)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Token de autenticacao para requisicoes de webhook
AUTH_TOKEN=

# --- Opcionais ---

# Porta do servidor Express (default: 3000)
PORT=3000

# Virtual host do RabbitMQ (default: /)
RABBITMQ_VHOST=/

# Tentativas maximas de reconexao ao RabbitMQ (default: 10)
MAX_RECONNECT_ATTEMPTS=10

# Comportamento do cache de filas/exchanges (default: false)
# true = Pula validação quando fila/exchange está em cache (mais rápido, mas risco de falso positivo se deletado manualmente)
# false = Sempre valida mesmo que esteja em cache (mais seguro, recomendado)
ENABLE_CACHE_SKIP=false

# Defina como "true" para pular o carregamento do .env (usado no Docker)
# DOCKER_ENV=true
